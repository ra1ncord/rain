{
    "exclude": [
        "dist"
    ],
    "compilerOptions": {
        "strict": true,
        "paths": {
            // Just to discourage from consuming the module directly
            "spitroast": ["./shims/emptyModule"],

            "@rain/*": ["./src/rain/*"],
            "@lib": ["./src/lib"],
            "@lib/*": ["./src/lib/*"],
            "@metro": ["./src/metro"],
            "@metro/*": ["./src/metro/*"],
            "@types": ["./src/lib/utils/types.ts"],
            "@assets": ["./src/assets"],
            "@assets/*": ["./src/assets/*"],
            "@plugins": ["./src/rain/plugins"],
            "@plugins/*": ["./src/rain/plugins/*"],
            "@api": ["./src/api"],
            "@api/*": ["./src/api/*"]
        },
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": true,
        "jsx": "react-jsx",
        "target": "esnext",

        "skipLibCheck": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "stripInternal": true
    }
}